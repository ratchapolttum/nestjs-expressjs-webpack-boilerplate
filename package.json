{
  "version": "1.0.0",
  "name": "nestjs-expressjs-webpack-boilerplate",
  "description": "Boilerplate for NestJS (Express.js)",
  "license": "MIT",
  "author": "ratchapolttum",
  "repository": {
    "type": "git",
    "url": "https://github.com/ratchapolttum/nestjs-expressjs-webpack-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/ratchapolttum/nestjs-expressjs-webpack-boilerplate/issues"
  },
  "scripts": {
    "lint": "eslint **/*.{cjs,js,json,json5,jsonc,jsonl,md,mjs,ts,yaml,yml}",
    "lint:fix": "eslint --fix **/*.{cjs,js,json,json5,jsonc,jsonl,md,mjs,ts,yaml,yml}",
    "build": "cross-env NODE_ENV=development nest build",
    "build:staging": "cross-env NODE_ENV=staging nest build",
    "build:production": "cross-env NODE_ENV=production nest build",
    "start": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest",
    "test:unit-watch": "jest --watch",
    "test:unit-coverage": "jest --coverage",
    "test:e2e": "jest --config ./e2e/jest-e2e.config.ts",
    "test:e2e-watch": "jest --config ./e2e/jest-e2e.config.ts --watch"
  },
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@nestjs/platform-express": "10.4.15",
    "express": "4.21.2",
    "reflect-metadata": "0.1.14",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@eslint/compat": "1.2.4",
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.17.0",
    "@eslint/markdown": "6.2.1",
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.15",
    "@suites/di.nestjs": "3.0.1",
    "@suites/doubles.jest": "3.0.1",
    "@suites/unit": "3.0.1",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.14",
    "@types/node": "20.17.10",
    "@types/source-map-support": "0.5.10",
    "@types/supertest": "6.0.2",
    "copy-webpack-plugin": "12.0.2",
    "cross-env": "7.0.3",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jsonc": "2.18.2",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-sonarjs": "3.0.1",
    "eslint-plugin-unicorn": "56.0.1",
    "eslint-plugin-unused-imports": "4.1.4",
    "eslint-plugin-yml": "1.16.0",
    "globals": "15.14.0",
    "jest": "29.7.0",
    "jsonc-eslint-parser": "2.4.0",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "terser-webpack-plugin": "5.3.11",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.6.3",
    "typescript-eslint": "8.19.1",
    "webpack": "5.97.1",
    "yaml-eslint-parser": "1.2.3"
  },
  "private": true,
  "engines": {
    "node": "^20"
  },
  "keywords": [
    "Node.js",
    "NPM",
    "Boilerplate",
    "Typescript",
    "Backend",
    "Linter",
    "Web Service APIs"
  ]
}
